{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "incremental": false,
    "noImplicitAny": true,
    "strict": true,
    "paths": {
      "@teif/shared": ["../shared/dist/index.d.ts"],
      "@teif/shared/types": ["../shared/dist/types/index.d.ts"],
      "@teif/shared/utils": ["../shared/dist/utils/index.d.ts"],
      "@teif/generated/zod": ["../prisma/generated/zod/index.ts"]
    },
    "noEmit": false,
    "listEmittedFiles": false
  },
  "include": ["src/**/*"]
}
